{
  "name": "tauri-xcompile-for-win",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "./scripts/generate-license.sh && npm run clean && ng build",
    "clean": "rm -rf dist",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "tauri": "tauri",
    "tauri:build:release": "tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc --no-bundle",
    "tauri:build:debug": "tauri build --debug --runner cargo-xwin --target x86_64-pc-windows-msvc --no-bundle",
    "tauri:check:gpl": "cd src-tauri && cargo deny check licenses",
    "ng:check:gpl": "license-checker-rseidelsohn --production=false --excludePackages \"tauri-xcompile-for-win@0.0.0\" --onlyAllow \"MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;BlueOak-1.0.0;MIT-0;CC0-1.0;CC-BY-4.0;CC-BY-3.0;0BSD\" --summary"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@primeicons/angular": "^8.0.0-rc.2",
    "@primeuix/themes": "^3.0.0-rc.1",
    "@tauri-apps/api": "^2.11.1",
    "primeng": "^22.0.0-rc.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.4",
    "angular-eslint": "22.1.0",
    "eslint": "^10.6.0",
    "jsdom": "^28.0.0",
    "license-checker-rseidelsohn": "^5.0.1",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.62.1",
    "vitest": "^4.0.8"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true
  }
}
